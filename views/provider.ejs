<script>
    // Helper untuk memformat saldo
    const formatRupiah = (number) => {
        // IDR format dengan 0 digit di belakang koma (Rp 10.000)
        return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(number);
    };

    /**
     * Mengambil data profil terbaru (terutama saldo) dari API
     * dan memperbarui tampilan header.
     */
    async function updateBalanceHeader() {
        const balanceHeaderEl = document.getElementById('user-balance-header');       // Desktop
        const balanceMobileEl = document.getElementById('user-balance-mobile');       // Dropdown Tablet
        const balanceMobileMenuEl = document.getElementById('user-balance-mobile-menu'); // Menu Mobile

        try {
            const response = await fetch('/api/user/profile-data'); 
            const data = await response.json();

            if (data.ok) {
                const formattedBalance = formatRupiah(data.balance);
                
                // Update SEMUA tampilan saldo TANPA LOADING STATE
                if (balanceHeaderEl) balanceHeaderEl.textContent = formattedBalance;
                if (balanceMobileEl) balanceMobileEl.textContent = formattedBalance;
                if (balanceMobileMenuEl) balanceMobileMenuEl.textContent = formattedBalance;

            } else {
                // Tampilkan pesan error jika gagal, tapi jangan ubah angka ke loading state
                const errorText = 'Error Saldo';
                console.error("Gagal memuat saldo:", data.message);
                
                // (Optional: Bisa menampilkan error, atau biarkan angka terakhir jika ini update berkala)
                // if (balanceHeaderEl) balanceHeaderEl.textContent = errorText; 
            }
        } catch (error) {
            // Tampilkan pesan error jika terjadi error jaringan
            console.error("Error jaringan saat memuat saldo:", error);
        }
    }

    // 1. Panggil fungsi saat DOM siap (Perbaikan masalah awal login/update)
    document.addEventListener('DOMContentLoaded', updateBalanceHeader); 
    
    // 2. ** PEMBARUAN OTOMATIS 10 DETIK **
    setInterval(updateBalanceHeader, 10000); // 10000 milidetik = 10 detik

</script>
<% } %>

