        // adjust scroll-top position so it sits above bottom-order-bar when visible
        function adjustScrollTopPosition() {
          if (!scrollTopBtn) return;
          const defaultBottom = 24; // px
          try {
            if (bottomBar && !bottomBar.classList.contains('hidden')) {
              const comp = window.getComputedStyle(bottomBar);
              const bottomOffset = parseFloat(comp.bottom) || 18;
              const height = bottomBar.getBoundingClientRect().height || 72;
              const gap = 12;
              const newBottom = Math.ceil(height + bottomOffset + gap);
              scrollTopBtn.style.bottom = `${newBottom}px`;
            } else {
              scrollTopBtn.style.bottom = `${defaultBottom}px`;
            }
          } catch (e) {
            scrollTopBtn.style.bottom = `${defaultBottom}px`;
          }
        }

        // observers (kept)
        function setupBottomBarObserver() {
          if (!orderSummaryEl || !bottomBar) return;
          const io = new IntersectionObserver((entries) => {
            entries.forEach(en => {
              if (en.isIntersecting) {
                bottomBar.classList.add('hidden');
                bottomBar.setAttribute('aria-hidden','true');
              } else {
                if (selectedProduct) {
                  bottomBar.classList.remove('hidden');
                  bottomBar.setAttribute('aria-hidden','false');
                }
              }
              adjustScrollTopPosition();
            });
          }, { root: null, threshold: 0.02 });

          io.observe(orderSummaryEl);
        }

        function setupBottomBar() {
          updateBottomBar(selectedProduct || null);
          setupBottomBarObserver();
          window.addEventListener('resize', () => {
            updateBottomBar(selectedProduct || null);
            adjustScrollTopPosition();
          });
          window.addEventListener('scroll', () => {
            if (!orderSummaryEl || !bottomBar) return;
            const r = orderSummaryEl.getBoundingClientRect();
            if (r.top < window.innerHeight && r.bottom > 0) {
              bottomBar.classList.add('hidden');
              bottomBar.setAttribute('aria-hidden','true');
            } else if (selectedProduct) {
              bottomBar.classList.remove('hidden');
              bottomBar.setAttribute('aria-hidden','false');
            }
            adjustScrollTopPosition();
          }, { passive: true });
        }

        (function setupScrollTopVisibility() {
          if (!scrollTopBtn) return;
          window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
              scrollTopBtn.style.display = 'block';
            } else {
              scrollTopBtn.style.display = 'none';
            }
            adjustScrollTopPosition();
          }, { passive: true });

          scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
        })();

        // -------------------------
        // Deposit methods + render (kept)
        // -------------------------
        function getCsrfToken() {
    return document.querySelector('meta[name="csrf-token"]').getAttribute('content');
}

        async function loadDepositMethods(type='') {
            try {
                const res = await fetch('/api/deposit-methods', {
                    method: 'POST',
                    headers: { 
                'Content-Type': 'application/json',
                'X-CSRF-Token': getCsrfToken()
            },
                    body: JSON.stringify({ type })
                });
                if (!res.ok) throw new Error('Gagal memuat metode pembayaran');
                const j = await res.json();
                if (!j.ok || !Array.isArray(j.data)) {
                    depositMethods = [];
                    renderDepositMethods();
                    return;
                }

                let mapped = (j.data || []).map(m => {
                    const nameRaw = m.name || m.method || m.label || m.nama || '';
                    const methodRaw = (m.method || m.code || m.id || nameRaw || '').toString();
                    const typeRaw = (m.type || m.tipe || '').toString().toLowerCase();
                    const minRaw = Number(m.min || m.minimum || m.min_deposit || 0);
                    const maxRaw = Number(m.max || m.maximum || m.max_deposit || 0);
                    return {
                        method: methodRaw,
                        id: String(methodRaw || '').toLowerCase(),
                        name: String(nameRaw || methodRaw || '').toString(),
                        type: String(typeRaw || '').toLowerCase(),
                        min: Number(!Number.isNaN(minRaw) ? minRaw : 0),
                        max: Number(!Number.isNaN(maxRaw) ? maxRaw : 0),
                        fee: Number(m.fee || 0),
                        fee_persen: Number(m.fee_persen || m.feePercent || 0),
                        status: (m.status || m.state || '').toString().toLowerCase(),
                        img_url: m.img_url || m.image || m.logo || null,
                        raw: m
                    };
                });

                const qrisfastIdx = mapped.findIndex(it => /qris.*fast|qrisfast|qris-?fast/.test(((it.name||it.method)||'').toLowerCase()));
                if (qrisfastIdx !== -1) {
                    const qf = mapped[qrisfastIdx];
                    qf.min = 500;
                    if (qf.raw) {
                        try {
                            if (typeof qf.raw.min !== 'undefined') qf.raw.min = 500;
                            if (qf.raw.minimum) qf.raw.minimum = 500;
                            if (qf.raw.min_deposit) qf.raw.min_deposit = 500;
                            if (qf.raw.limits && typeof qf.raw.limits === 'object') {
                                qf.raw.limits.min = 500;
                                qf.raw.limits.minimum = 500;
                            }
                        } catch(e){}
                    }
                    mapped.splice(qrisfastIdx, 1);
                    mapped.unshift(qf);
                }

                depositMethods = mapped;
                renderDepositMethods();
            } catch (err) {
                console.error('loadDepositMethods', err);
                depositMethods = [];
                renderDepositMethods();
            }
        }

        function renderDepositMethods() {
            paymentGrid.innerHTML = '';
            if (!depositMethods.length) {
                paymentGrid.innerHTML = '<div class="col-span-full text-sm text-gray-500 dark:text-slate-400">Metode pembayaran tidak tersedia.</div>';
                return;
            }

            for (const m of depositMethods) {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'payment-card';
                
                // [LOGIC SALDO REVISI] 
                const isSaldo = (m.method === 'SALDO');
                
                // Default value
                let userBalance = 0;
                let isLoggedIn = false;

                if (isSaldo) {
                    // Jika metode SALDO, paksa ambil data dari variable Global EJS
                    // Ini memperbaiki bug saldo 0 / tidak sesuai session API
                    isLoggedIn = IS_USER_LOGGED_IN;
                    userBalance = isLoggedIn ? Number(CURRENT_USER_BALANCE) : 0;
                }
                
                // Tentukan status disable
                let isDisabled = false;
                let statusText = '';
                
                // Cek status aktif dari API
                if (m.status !== 'aktif' && m.status !== 'active') {
                    isDisabled = true;
                }
                
                if (isSaldo) {
                    if (!isLoggedIn) {
                        isDisabled = true;
                        statusText = 'Login diperlukan';
                    } else if (selectedProduct) {
                         // Validasi saldo user (dari EJS) vs harga produk
                         const price = getPrice(selectedProduct);
                         if (userBalance < price) {
                             isDisabled = true;
                             statusText = 'Saldo tidak cukup';
                         }
                    }
                }

                if (isDisabled) btn.classList.add('disabled');
                
                btn.dataset.method = m.method || m.id;

                const needsDarkBg = (m.name === 'QRIS' || m.name === 'QRIS INSTANT') ? 'dark:bg-white' : '';
                
                // Tampilan Icon
                let iconHtml = '';
                if (isSaldo) {
                     iconHtml = `<div class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center mb-1"><i class="fa-solid fa-wallet text-xl"></i></div>`;
                } else if (m.img_url) {
                     iconHtml = `<img src="${escapeHtml(m.img_url)}" alt="${escapeHtml(m.name)}" class="max-h-10 ${needsDarkBg} mb-1" />`;
                } else {
                     iconHtml = `<div class="font-semibold mb-1">${escapeHtml((m.name||'').slice(0,2).toUpperCase())}</div>`;
                }

                // [TAMPILAN FEE / SALDO]
                let feeHtml = '';
                if (isSaldo) {
                    if (isLoggedIn) {
                        // Tampilkan saldo user yang benar
                        btn.title = `Saldo Anda: Rp ${formatCurrency(userBalance)}`;
                        feeHtml = `<div class="text-xs text-blue-600 mt-1 font-bold">Saldo: Rp ${formatCurrency(userBalance)}</div>`;
                        
                        // Jika disable karena saldo kurang, beri info merah
                        if (statusText === 'Saldo tidak cukup') {
                             feeHtml += `<div class="text-[10px] text-red-500 mt-0.5 font-semibold">Kurang Rp ${formatCurrency(getPrice(selectedProduct) - userBalance)}</div>`;
                        } else if (statusText) {
                             feeHtml += `<div class="text-[10px] text-red-500 mt-0.5">${statusText}</div>`;
                        }
                    } else {
                        btn.title = 'Silakan Login';
                        feeHtml = `<div class="text-xs text-red-500 mt-1">Silakan Login</div>`;
                    }
                } else {
                    // Logic Fee & Persen (Sesuai Permintaan: Fee: Rp 200 (+0.7%))
                    const feeFlat = m.fee || 0;
                    const feePercent = m.fee_percent || m.fee_persen || 0;
                    
                    let feeString = `Rp ${formatCurrency(feeFlat)}`;
                    if (feePercent > 0) {
                        feeString += ` (+${feePercent}%)`;
                    }

                    btn.title = `${m.name} (Min: Rp ${formatCurrency(m.min||0)})`;
                    feeHtml = `<div class="text-xs text-green-600 mt-1">Fee: ${feeString}</div>`;
                }

                btn.innerHTML = `
                    <div class="w-full flex items-center justify-center flex-col">
                        ${iconHtml}
                    </div>
                    <div class="label text-center leading-tight">${escapeHtml(m.name)}</div>
                    ${feeHtml}
                `;

                // Event Listener Click
                if (!isDisabled) {
                    btn.addEventListener('click', () => {
                        if (!selectedProduct) { alert('Pilih produk terlebih dahulu.'); return; }
                        
                        const price = getPrice(selectedProduct);

                        if (isSaldo) {
                            if (userBalance < price) return alert(`Saldo akun Anda tidak mencukupi. (Saldo: Rp ${formatCurrency(userBalance)})`);
                        } else {
                            if (m.min && price < m.min) return alert(`Nominal produk (Rp ${formatCurrency(price)}) kurang dari minimal metode ini.`);
                            if (m.max && m.max > 0 && price > m.max) return alert('Nominal melebihi batas maksimal metode ini.');
                        }

                        // Remove selected class from others
                        document.querySelectorAll('#payment-methods-grid .payment-card').forEach(pc => pc.classList.remove('selected'));
                        btn.classList.add('selected');
                        
                        selectedDepositMethod = m;
                        selectedMethodEl.textContent = m.type.toUpperCase() + ' - ' + m.name;
                        
                        // Penting: Update summary agar fee/total terhitung ulang
                        updateOrderSummary(selectedProduct);

                        // Handle Form Visibility (Email/OVO)
                        if (emailWrapper) {
                          emailWrapper.classList.remove('hidden');
                          if (emailInput) emailInput.setAttribute('required','');
                        }
                        
                        if (ovoPhoneWrapper) {
                            const methodName = (m.name || '').toLowerCase();
                            if (methodName.includes('ovo')) {
                                ovoPhoneWrapper.classList.remove('hidden');
                                if (ovoPhoneInput) ovoPhoneInput.setAttribute('required','');
                            } else {
                                ovoPhoneWrapper.classList.add('hidden');
                                if (ovoPhoneInput) { ovoPhoneInput.removeAttribute('required'); ovoPhoneInput.value = ''; }
                            }
                        }

                        // Auto collapse accordion
                        try {
                            if (paymentMethodsWrapperEl) {
                                paymentMethodsWrapperEl.classList.add('collapsed');
                                if (paymentToggleBtnEl) paymentToggleBtnEl.setAttribute('aria-expanded', 'false');
                                if (paymentToggleIcon) paymentToggleIcon.classList.add('rotate');
                            }
                        } catch (e) {}
                    });
                } else {
                    // Handler jika tombol disabled (UX Feedback)
                    btn.addEventListener('click', () => {
                        if (isSaldo && !isLoggedIn) {
                             if(confirm('Metode ini khusus member. Login sekarang?')) window.location.href = '/login';
                        } else if (isSaldo && isLoggedIn) {
                             // Hitung kekurangan
                             const diff = (selectedProduct ? getPrice(selectedProduct) : 0) - userBalance;
                             alert(`Saldo tidak cukup.\nSaldo Anda: Rp ${formatCurrency(userBalance)}\nKekurangan: Rp ${formatCurrency(diff)}`);
                        }
                    });
                    
                    // Visual disabled tapi masih bisa diklik untuk alert
                    if (isSaldo) {
                        btn.style.opacity = '0.6';
                        btn.style.cursor = 'pointer'; 
                    } else {
                        btn.setAttribute('disabled','disabled');
                    }
                }

                paymentGrid.appendChild(btn);
            }
        }

        // -------------------------
        // Create deposit and proceed (kept, extended with email & ML merged id)
        // -------------------------
        // -------------------------
        // Create deposit and proceed
        // -------------------------
        async function createDeposit() {
            if (!selectedProduct) { alert('Pilih produk terlebih dahulu'); return; }
            if (!selectedDepositMethod) { alert('Pilih metode pembayaran terlebih dahulu'); return; }

            // ensure ML hidden user-id updated
            updateHiddenUserId();
            const rawInput = (userIdInput && userIdInput.value || '').trim();
            const { userId } = parseUserInput(rawInput);
            if (!rawInput) { alert('Isi ID/nomor/email tujuan terlebih dahulu'); if (userIdInput) userIdInput.focus(); return; }

            const ovoPhone = ovoPhoneInput ? (ovoPhoneInput.value || '').trim() : '';
            if (isOVO(selectedDepositMethod.method) && ovoPhoneInput) {
                if (!ovoPhone) {
                    alert('Masukkan nomor OVO terlebih dahulu.');
                    ovoPhoneInput.focus();
                    return;
                }
                const phoneRegex = /^(\+62|62|0)8[1-9][0-9]{6,9}$/;
                if (!phoneRegex.test(ovoPhone)) {
                    alert('Masukkan nomor OVO yang valid (contoh: 081234567890).');
                    ovoPhoneInput.focus();
                    return;
                }
            }

            // email validation (only if email-wrapper visible)
            let emailVal = '';
            if (emailWrapper && !emailWrapper.classList.contains('hidden')) {
                emailVal = (emailInput && emailInput.value || '').trim();
                if (!emailVal) {
                    alert('Masukkan email untuk konfirmasi pembayaran.');
                    if (emailInput) emailInput.focus();
                    return;
                }
            }

            const code = getCode(selectedProduct) || getName(selectedProduct);
            const price = getPrice(selectedProduct);
            const target = rawInput;
            const type = selectedDepositMethod.type || 'ewallet';
            
            // [REVISI] Pastikan Method terkirim sebagai 'SALDO' jika user pilih saldo
            // Jangan sampai tertimpa jadi QRISFAST
            let method = selectedDepositMethod.method || 'QRISFAST';
            if (method === 'SALDO') {
                method = 'SALDO'; 
            } else if (method.toUpperCase() === 'QRIS INSTANT') {
                method = 'QRISFAST';
            }

            if (selectedDepositMethod.min && price < selectedDepositMethod.min) return alert('Nominal lebih kecil dari minimal metode');
            if (selectedDepositMethod.max && selectedDepositMethod.max > 0 && price > selectedDepositMethod.max) return alert('Nominal melebihi maksimal metode');

            checkoutBtn.disabled = true;
            checkoutBtn.textContent = 'Memproses Transaksi...';

            try {
                const requestData = {
                    price: totalPrice,
                    type,
                    method,
                    email: emailVal,
                    phone: ovoPhone,
                    product: {
                        name: getName(selectedProduct),
                        code: getCode(selectedProduct),
                        price: price,
                        target: target
                    }
                };
                
                if (isOVO(selectedDepositMethod.method) && ovoPhoneInput) {
                    requestData.phone = ovoPhoneInput.value.trim();
                }

                const res = await fetch('/api/create-deposit', {
                    method: 'POST',
                    headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': getCsrfToken()
            },
                    body: JSON.stringify(requestData)
                });
                
                const j = await res.json();
                
                // [REVISI] Menangani Error dari Server (Misal: Saldo Habis, Gagal Provider)
                if (!res.ok || !j.ok) {
                    throw new Error(j.message || 'Gagal membuat transaksi');
                }
                
                // Sukses -> Redirect ke Payment Page
                window.location.href = `/payment?trx_id=${encodeURIComponent(j.order_id || (j.deposit && j.deposit.id))}`;
            
            } catch (err) {
                console.error(err);
                // Tampilkan pesan error spesifik dari server (misal: "Saldo Anda dikembalikan")
                alert(err.message || 'Terjadi kesalahan saat memproses transaksi.');
            } finally {
                checkoutBtn.disabled = false;
                checkoutBtn.textContent = 'Lanjutkan Pembayaran';
            }
        }

        // -------------------------
        // Name check (kept)
        // -------------------------
        async function checkName() {
            // ensure ML hidden user-id updated
            updateHiddenUserId();

            const rawInput = (userIdInput.value || '').trim();
            const { userId } = parseUserInput(rawInput);
            if (!userId) return alert('Masukkan ID/nomor/email tujuan terlebih dahulu.');

            nameCheckResult.textContent = 'Memeriksa...';
            try {
                const res = await fetch('/api/account-check', { method:'POST', headers: {
                'Content-Type': 'application/json'
            }, body: JSON.stringify({ user_id: userId }) });
                if (!res.ok) { nameCheckResult.textContent = 'Fitur check nama belum tersedia di server.'; nameCheckResult.classList.remove('text-green-600'); nameCheckResult.classList.add('text-yellow-500'); return; }
                const j = await res.json();
                if (j && j.ok && j.name) { nameCheckResult.textContent = `Nama akun: ${j.name}`; nameCheckResult.classList.remove('text-yellow-500'); nameCheckResult.classList.add('text-green-600'); } 
                else { nameCheckResult.textContent = 'Tidak ditemukan nama akun.'; nameCheckResult.classList.remove('text-green-600'); nameCheckResult.classList.add('text-yellow-500'); }
            } catch (err) {
                nameCheckResult.textContent = 'Fitur check nama tidak tersedia (server).';
                nameCheckResult.classList.remove('text-green-600'); nameCheckResult.classList.add('text-yellow-500');
            }
        }

        // -------------------------
        // Insert nominal buttons (minimal, non-invasive)
        // - IDs: nominal-pulsa, nominal-data, nominal-reset
        // - Inserts BEFORE #filters-container so it sits below H2 and above types
        // - Default now: show 'Tampilkan Semua' active
        // -------------------------
        function ensureNominalButtons() {
            try {
                if (String(categorySlug || '').toLowerCase() !== 'pulsa-data') return;
                if (!filtersContainer || !filtersContainer.parentNode) return;
                if (document.getElementById('nominal-pulsa')) return; // already inserted

                const wrap = document.createElement('div');
                wrap.className = 'mb-3 flex items-center gap-2';
                wrap.style.flexWrap = 'wrap';

                const btnPulsa = document.createElement('button');
                btnPulsa.id = 'nominal-pulsa';
                btnPulsa.type = 'button';
                btnPulsa.className = 'px-3 py-1.5 rounded-full border text-sm font-medium';
                btnPulsa.textContent = 'Pulsa';

                const btnData = document.createElement('button');
                btnData.id = 'nominal-data';
                btnData.type = 'button';
                btnData.className = 'px-3 py-1.5 rounded-full border text-sm font-medium';
                btnData.textContent = 'Data';

                const btnReset = document.createElement('button');
                btnReset.id = 'nominal-reset';
                btnReset.type = 'button';
                btnReset.className = 'px-2 py-1 rounded-full border text-xs font-medium';
                btnReset.textContent = 'Tampilkan Semua';

                wrap.appendChild(btnPulsa);
                wrap.appendChild(btnData);
                wrap.appendChild(btnReset);

                filtersContainer.parentNode.insertBefore(wrap, filtersContainer);

                btnPulsa.addEventListener('click', () => setNominalActive('pulsa'));
                btnData.addEventListener('click', () => setNominalActive('data'));
                btnReset.addEventListener('click', () => setNominalActive(null));

                // default: show 'Tampilkan Semua' active on open
                setNominalActive(null);
            } catch (e) {
                console.warn('ensureNominalButtons failed', e);
            }
        }

        // -------------------------
        // set nominal active (minimal & compatible)
        // - ensures when switching nominal, selectedType becomes 'Semua' (if present)
        // -------------------------
        function setNominalActive(state) {
            selectedNominal = (state === 'pulsa' || state === 'data') ? state : null;

            const bPulsa = document.getElementById('nominal-pulsa');
            const bData = document.getElementById('nominal-data');
            const bReset = document.getElementById('nominal-reset');

            const activeClass = 'bg-blue-600 text-white border-transparent';
            const inactiveClass = 'bg-white dark:bg-slate-700 text-gray-700 dark:text-slate-200 border border-gray-200 dark:border-slate-600';

            if (bPulsa) bPulsa.className = (selectedNominal === 'pulsa') ? `px-3 py-1.5 rounded-full text-sm font-medium ${activeClass}` : `px-3 py-1.5 rounded-full text-sm font-medium ${inactiveClass}`;
            if (bData) bData.className = (selectedNominal === 'data') ? `px-3 py-1.5 rounded-full text-sm font-medium ${activeClass}` : `px-3 py-1.5 rounded-full text-sm font-medium ${inactiveClass}`;
            if (bReset) bReset.className = (selectedNominal === null) ? `px-2 py-1 rounded-full text-xs font-medium ${activeClass}` : `px-2 py-1 rounded-full text-xs font-medium ${inactiveClass}`;

            // rebuild types for the newly selected nominal
            buildTypes();

            // When switching nominal, ensure selectedType becomes 'Semua' (if present),
            // otherwise the first type — this ensures data->pulsa switch goes to 'Semua' for pulsa.
            if (types && types.length) {
                if (types.includes('Semua')) selectedType = 'Semua';
                else selectedType = types[0];
            } else {
                selectedType = null;
            }

            renderTypeFilters();
            renderProducts();

            // if selectedProduct no longer fits filter, clear it
            if (selectedProduct) {
                const ok = (selectedNominal === 'pulsa' ? isPulsaProduct(selectedProduct) : (selectedNominal === 'data' ? isDataProduct(selectedProduct) : true));
                if (!ok) {
                    selectedProduct = null;
                    updateOrderSummary(null);
                }
            }
        }

        // -------------------------
        // Init: sanitize, build types, render
        // -------------------------
        (function init(){
            products = sanitize(allProducts || []);
            products.sort((a,b)=> getPrice(a) - getPrice(b));

            // add nominal buttons only if categorySlug is pulsa-data (ensureNominalButtons sets default to 'Semua')
            try { ensureNominalButtons(); } catch(e){ console.warn('ensureNominalButtons failed', e); }

            buildTypes();
            renderTypeFilters();
            renderProducts();
            loadDepositMethods('');

            sortSelect && sortSelect.addEventListener('change', ()=> renderProducts());
            nameCheckBtn && nameCheckBtn.addEventListener('click', checkName);
            checkoutBtn && checkoutBtn.addEventListener('click', createDeposit);
            
            // theme & UI bits (kept)
            const THEME_KEY = '<%= config.name %>_theme';
            const themeToggle = document.getElementById('theme-toggle');
            const mobileThemeToggle = document.getElementById('mobile-theme-toggle');
            const themeIcon = document.getElementById('theme-icon');
            const mobileThemeIcon = document.getElementById('mobile-theme-icon');
            const themeDot = document.getElementById('theme-dot');

            function applyThemeClass(theme){ if (theme === 'dark') document.documentElement.classList.add('dark'); else document.documentElement.classList.remove('dark'); }
            function getInitialTheme(){ const saved = localStorage.getItem(THEME_KEY); if (saved === 'dark' || saved === 'light') return saved; const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches; return prefersDark ? 'dark' : 'light'; }

            function setTheme(theme, persist = true){
                applyThemeClass(theme);
                const isDark = theme === 'dark';
                if (themeToggle) { themeToggle.setAttribute('aria-checked', isDark ? 'true' : 'false'); themeIcon && (themeIcon.innerHTML = isDark ? '<i class="fa-solid fa-moon"></i>' : '<i class="fa-solid fa-sun"></i>'); themeIcon && themeIcon.classList.add('rotate'); setTimeout(()=> themeIcon && themeIcon.classList.remove('rotate'), 300); if (themeDot) themeDot.style.transform = isDark ? 'translateX(22px)' : 'translateX(0)'; }
                if (mobileThemeIcon) mobileThemeIcon.className = isDark ? 'fa-solid fa-moon text-slate-200' : 'fa-solid fa-sun text-yellow-400';
                if (persist) localStorage.setItem(THEME_KEY, theme);
            }

            function toggleTheme(){ const cur = document.documentElement.classList.contains('dark') ? 'dark' : 'light'; setTheme(cur === 'dark' ? 'light' : 'dark', true); }

            (function initTheme(){ const initial = getInitialTheme(); setTheme(initial, false); })();

            if (themeToggle) themeToggle.addEventListener('click', toggleTheme);
            if (themeToggle) themeToggle.addEventListener('keydown', (e) => { if (e.key === ' ' || e.key === 'Spacebar' || e.key === 'Enter') { e.preventDefault(); toggleTheme(); } });
            if (mobileThemeToggle) mobileThemeToggle.addEventListener('click', toggleTheme);

            const menuToggle = document.getElementById('menu-toggle');
            const mobileMenu = document.getElementById('mobile-menu');
            if (menuToggle && mobileMenu) menuToggle.addEventListener('click', ()=> mobileMenu.classList.toggle('hidden'));

            const scrollTopBtnLocal = document.getElementById('scroll-top');
            if (scrollTopBtnLocal) {
                window.addEventListener('scroll', ()=> { if (window.scrollY > 300) scrollTopBtnLocal.style.display = 'block'; else scrollTopBtnLocal.style.display = 'none'; });
            }

            const ye = document.getElementById('currentYear'); if (ye) ye.textContent = new Date().getFullYear();

            // payment methods toggle behavior (kept)
            if (paymentToggleBtnEl) paymentToggleBtnEl.setAttribute('aria-expanded', 'true');
            if (paymentToggleIcon) paymentToggleIcon.classList.remove('rotate');

            if (paymentToggleBtnEl && paymentMethodsWrapperEl) {
                paymentToggleBtnEl.addEventListener('click', (e) => {
                    e.preventDefault();
                    const isCollapsed = paymentMethodsWrapperEl.classList.toggle('collapsed');
                    if (isCollapsed) {
                        paymentToggleBtnEl.setAttribute('aria-expanded', 'false');
                        if (paymentToggleIcon) paymentToggleIcon.classList.add('rotate');
                    } else {
                        paymentToggleBtnEl.setAttribute('aria-expanded', 'true');
                        if (paymentToggleIcon) paymentToggleIcon.classList.remove('rotate');
                        const firstCard = paymentMethodsWrapperEl.querySelector('.payment-card:not(.disabled)');
                        if (firstCard) firstCard.focus({ preventScroll: true });
                    }
                });

                paymentToggleBtnEl.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' || e.key === ' ' || e.key === 'Spacebar') {
                        e.preventDefault();
                        paymentToggleBtnEl.click();
                    }
                });
            }

            // ensure email hidden on load
            try {
              if (emailWrapper) emailWrapper.classList.add('hidden');
              if (emailInput) emailInput.removeAttribute('required');
            } catch(e){}

            // initialize ML merge if provider is mobile-legends and inputs exist -> ensure hidden user-id is in sync
            try {
              // if ML inputs are present but userIdInput may be hidden, sync them now
              if (providerSlug === 'mobile-legends-bb') {
                // prefer ML visible inputs if present
                updateHiddenUserId();
              } else {
                // if not ML, still ensure selectedTarget shows current userId value
                if (selectedTargetEl && userIdInput) selectedTargetEl.textContent = userIdInput.value || '-';
              }
            } catch(e){}

            // setup bottom bar (observer & handlers)
            try { setupBottomBar(); } catch(e){ console.warn('setupBottomBar failed', e); }
        })();
    </script>

</body>
</html>