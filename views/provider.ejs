    	<script>
    	// --- KODE REVISI: Mencegah Refresh saat Enter ---

const userForm = document.getElementById('user-data-form');

if (userForm) {
    userForm.addEventListener('keydown', function(e) {
        // Cek jika tombol yang ditekan adalah ENTER (KeyCode 13)
        if (e.key === 'Enter' || e.keyCode === 13) {
            e.preventDefault(); // 1. Mencegah form submit / refresh halaman
            e.stopPropagation(); // 2. Hentikan event bubbling

            // 3. Tutup keyboard HP (opsional, agar user merasa input selesai)
            if (document.activeElement) {
                document.activeElement.blur();
            }
            
            return false;
        }
    });

    // Tambahan keamanan: Mencegah event submit standar HTML
    userForm.addEventListener('submit', function(e) {
        // Kita prevent default submit karena proses order Anda menggunakan AJAX/Fetch (JS)
        // bukan submit form HTML biasa.
        e.preventDefault(); 
        return false;
    });
}

  (function(){
    const form = document.getElementById('user-data-form');
    if (!form) return;

    // hanya aktif kalau provider mobile-legend (elemen akan ada/enggak tergantung EJS)
    const mlId = document.getElementById('ml-id-input');
    const mlServer = document.getElementById('ml-server-input');
    const hiddenUserId = document.getElementById('user-id'); // selalu ada: hidden (mobile) atau visible (lain)

    function updateHidden() {
      if (!hiddenUserId) return;
      if (mlId && mlServer) {
        const idVal = mlId.value.trim();
        const serverVal = mlServer.value.trim();
        if (!idVal) {
          hiddenUserId.value = '';
          hiddenUserId.removeAttribute('required');
        } else {
          hiddenUserId.value = serverVal ? `${idVal}|${serverVal}` : idVal;
          hiddenUserId.setAttribute('required', ''); // pastikan required jika ada isi
        }
      }
      // jika bukan mobile-legend, tidak perlu gabung (hiddenUserId adalah input visible)
    }

    // event listeners untuk live update (only when ML inputs present)
    if (mlId && mlServer) {
      mlId.addEventListener('input', updateHidden);
      mlServer.addEventListener('input', updateHidden);
      // inisialisasi awal
      updateHidden();
    }

    // extra safety: sebelum submit, pastikan hiddenUserId valid
    form.addEventListener('submit', function (e) {
      if (!hiddenUserId) return;
      // jika kosong -> block submit dan beri feedback
      if (!hiddenUserId.value.trim()) {
        e.preventDefault();
        // simple feedback; ubah sesuai UI (toast/modal) kalau perlu
        const warn = document.createElement('div');
        warn.className = 'mt-2 text-sm text-red-600';
        warn.textContent = 'Mohon isi ID dan Server (untuk Mobile Legends) atau ID tujuan.';
        // append once
        if (!form.querySelector('.ml-warning')) {
