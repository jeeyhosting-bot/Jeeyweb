<%
    // pilih logo dari produk (fallback)
    function _pickLogoFromProducts(products) {
        if (!products || !products.length) return null;
        for (let i = 0; i < products.length; i++) {
            const p = products[i] || {};
            if (p.img_url) return p.img_url;
            if (p.img) return p.img;
            if (p.logo) return p.logo;
            if (p.image) return p.image;
        }
        return null;
    }

    // providerLogo: diharapkan dikirim dari server (route) — ini prioritas utama
    const serverLogo = (typeof providerLogo !== 'undefined' && providerLogo) ? String(providerLogo) : null;
    const apiLogo = _pickLogoFromProducts(products || []);
    const finalLogo = serverLogo || apiLogo || null;

    // --- LOGIC KHUSUS OG:IMAGE (AUTO CONVERT TO JPG) ---
    let ogImageUrl = null;
    if (finalLogo) {
        // 1. Kita butuh URL absolute (https://...) untuk og:image
        // Asumsi 'finalLogo' berawalan '/' (misal: /images/logo.png)
        const rawUrl = `https://${config.domain}${finalLogo}`;

        // 2. Gunakan 'wsrv.nl' untuk convert realtime ke JPG.
        // Parameter: url = url asli, output = jpg
        ogImageUrl = `https://wsrv.nl/?url=${encodeURIComponent(rawUrl)}&output=jpg`;
    }
    // ----------------------------------------------------

    const totalProducts = (products && products.length) ? products.length : 0;
    const safeProviderName = providerName || providerSlug || 'Provider';

    // bantu escape single-quote untuk memasukkan URL ke attribute onerror
    function _escapeForAttr(s) {
        if (!s) return '';
        return String(s).replace(/'/g, "\\'");
    }
%>
	
