  <!-- ========== Scripts: accordion, search, theme, mobile menu ========== -->
  <script>
    // Theme toggle (copied/compatible with header)
    const THEME_KEY = '<%= config.name %>_theme';
    const themeToggle = document.getElementById('theme-toggle');
    const mobileThemeToggle = document.getElementById('mobile-theme-toggle');
    const themeIcon = document.getElementById('theme-icon');
    const mobileThemeIcon = document.getElementById('mobile-theme-icon');

    function applyThemeClass(theme){ 
      if (theme === 'dark') document.documentElement.classList.add('dark'); 
      else document.documentElement.classList.remove('dark'); 
    }
    function getInitialTheme(){ 
      const saved = localStorage.getItem(THEME_KEY); 
      if (saved === 'dark' || saved === 'light') return saved; 
      const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches; 
      return prefersDark ? 'dark' : 'light'; 
    }
    function setTheme(theme, persist = true){
      applyThemeClass(theme);
      const isDark = theme === 'dark';
      if (themeToggle) {
        themeToggle.setAttribute('aria-checked', isDark ? 'true' : 'false');
        themeIcon && (themeIcon.innerHTML = isDark ? '<i class="fa-solid fa-moon"></i>' : '<i class="fa-solid fa-sun"></i>');
        themeIcon && themeIcon.classList.add('rotate');
        setTimeout(()=> themeIcon && themeIcon.classList.remove('rotate'), 300);
      }
      if (mobileThemeIcon) mobileThemeIcon.className = isDark ? 'fa-solid fa-moon text-slate-200' : 'fa-solid fa-sun text-yellow-400';
      if (persist) localStorage.setItem(THEME_KEY, theme);
    }
    function toggleTheme(){ 
      const cur = document.documentElement.classList.contains('dark') ? 'dark' : 'light'; 
      setTheme(cur === 'dark' ? 'light' : 'dark', true); 
    }
    (function initTheme(){ 
      const initial = getInitialTheme(); 
      setTheme(initial, false); 
    })();
    if (themeToggle) themeToggle.addEventListener('click', toggleTheme);
    if (themeToggle) themeToggle.addEventListener('keydown', (e) => { 
      if (e.key === ' ' || e.key === 'Spacebar' || e.key === 'Enter') { e.preventDefault(); toggleTheme(); } 
    });
    if (mobileThemeToggle) mobileThemeToggle.addEventListener('click', toggleTheme);

    // Mobile menu
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener('click', ()=> {
        mobileMenu.classList.toggle('hidden');
        const icon = menuToggle.querySelector('i');
        if (mobileMenu.classList.contains('hidden')) {
          icon.className = 'fas fa-bars text-xl text-gray-700 dark:text-slate-200';
        } else {
          icon.className = 'fas fa-times text-xl text-gray-700 dark:text-slate-200';
        }
      });
    }

    // Accordion logic (custom for animation + aria)
    document.querySelectorAll('.faq-item').forEach(item => {
      const btn = item.querySelector('.faq-toggle');
      const content = item.querySelector('.accordion-content');

      // compute full height helper
      // Kode Baru
function setMaxHeightOpen(){
  // Kita set nilai cukup besar untuk animasi awal, 
  // lalu CSS !important (di langkah 1) akan mengambil alih untuk membatasi scroll
  content.style.maxHeight = (content.scrollHeight + 50) + 'px'; 
  item.classList.add('accordion-open');
}

// TAMBAHAN: Perbaiki tinggi otomatis saat layar di-resize agar text tidak kepotong
window.addEventListener('resize', () => {
  document.querySelectorAll('.accordion-open .accordion-content').forEach(el => {
     el.style.maxHeight = (el.scrollHeight + 50) + 'px';
  });
});
      function setMaxHeightClosed(){
        content.style.maxHeight = 0;
        item.classList.remove('accordion-open');
      }

      // init closed
      setMaxHeightClosed();

      btn.addEventListener('click', ()=> {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        // close all siblings (optional behavior: allow one open only)
        // close other items:
        document.querySelectorAll('.faq-item').forEach(sib => {
          if (sib !== item) {
            const sibBtn = sib.querySelector('.faq-toggle');
            const sibContent = sib.querySelector('.accordion-content');
            sibBtn && sibBtn.setAttribute('aria-expanded','false');
            sibContent && (sibContent.style.maxHeight = 0);
            sib.classList.remove('accordion-open');
          }
        });

        if (expanded) {
          btn.setAttribute('aria-expanded','false');
          setMaxHeightClosed();
          btn.querySelector('i').style.transform = 'rotate(0deg)';
        } else {
          btn.setAttribute('aria-expanded','true');
          setMaxHeightOpen();
          btn.querySelector('i').style.transform = 'rotate(180deg)';
        }
      });

      // make header clickable (accessibility)
      const header = item.querySelector('header');
      header && header.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          btn.click();
        }
      });
    });

    // Search & filter
    const search = document.getElementById('faq-search');
    const clearBtn = document.getElementById('clear-search');
    const list = document.getElementById('faq-list');
    const empty = document.getElementById('faq-empty');

    function normalize(text) {
      return text.trim().toLowerCase();
    }

    search.addEventListener('input', (e) => {
      const q = normalize(e.target.value);
      if (q.length > 0) clearBtn.classList.remove('hidden'); else clearBtn.classList.add('hidden');

      let visible = 0;
      document.querySelectorAll('.faq-item').forEach(item => {
        const title = normalize(item.querySelector('h3').innerText || '');
        const body = normalize(item.querySelector('.accordion-content').innerText || '');
        const meta = normalize(item.getAttribute('data-category') || '');
        const match = q === '' || title.includes(q) || body.includes(q) || meta.includes(q);
        item.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      empty.classList.toggle('hidden', visible !== 0);
    });

    clearBtn.addEventListener('click', () => {
      search.value = '';
      search.dispatchEvent(new Event('input'));
      clearBtn.classList.add('hidden');
      search.focus();
    });

    // Category filter (desktop)
    document.querySelectorAll('.category-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.innerText.trim();
        // reset search
        search.value = '';
        search.dispatchEvent(new Event('input'));

        if (cat === 'Semua') {
          document.querySelectorAll('.faq-item').forEach(i => i.style.display = '');
        } else {
          document.querySelectorAll('.faq-item').forEach(i => {
            i.style.display = (i.getAttribute('data-category') === cat) ? '' : 'none';
          });
        }
      });
    });
  </script>
</body>
</html>
