<!DOCTYPE html>
<html lang="id" class="antialiased">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>FAQ — <%= config.name %></title>

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config = { darkMode: 'class' };</script>

  <!-- Fonts & Icons (sama seperti file awal) -->
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="icon" type="image/png" href="/img/favicon.png" />
<link rel="apple-touch-icon" href="/img/favicon.png" />
  <style>
    :root { --card-bg: rgba(255,255,255,0.6); }
    html,body { font-family: 'Montserrat', system-ui, -apple-system, "Helvetica Neue", Arial; }
    .accordion-content { max-height: 0; transition: max-height 0.32s ease, padding 0.24s ease; overflow: hidden; }
    /* Kode Baru */
.accordion-open .accordion-content { 
  padding-top: 1rem; 
  padding-bottom: 1rem;
  overflow-y: auto; /* Izinkan scroll vertikal */
  max-height: 300px !important; /* Batasi tinggi text (opsional, sesuaikan kebutuhan) */
  /* Gunakan !important agar menang melawan inline-style dari JS saat sudah terbuka */
}
    /* aesthetic glass */
    .glass {
      background: linear-gradient(180deg, rgba(255,255,255,0.6), rgba(255,255,255,0.5));
      backdrop-filter: blur(6px);
    }
    .dark .glass {
      background: linear-gradient(180deg, rgba(15,23,42,0.6), rgba(15,23,42,0.5));
    }
    /* subtle focus */
    .focus-ring:focus { outline: none; box-shadow: 0 0 0 4px rgba(99,102,241,0.12); border-color: rgba(99,102,241,0.9); }
  </style>
</head>
<body class="bg-gray-50 text-gray-800 dark:bg-slate-900 dark:text-slate-100">

  <!-- ========== Header (copy dari kode awal) ========== -->
