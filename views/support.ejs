  <!-- ========== SCRIPT: theme toggle ========== -->
  <script>
    // Theme toggle logic
    const THEME_KEY = '<%= config.name %>_theme';
    const themeToggle = document.getElementById('theme-toggle');
    const mobileThemeToggle = document.getElementById('mobile-theme-toggle');
    const themeIcon = document.getElementById('theme-icon');
    const mobileThemeIcon = document.getElementById('mobile-theme-icon');
    const themeDot = document.getElementById('theme-dot');
    
    function applyThemeClass(theme){ 
      if (theme === 'dark') document.documentElement.classList.add('dark'); 
      else document.documentElement.classList.remove('dark'); 
    }
    
    function getInitialTheme(){ 
      const saved = localStorage.getItem(THEME_KEY); 
      if (saved === 'dark' || saved === 'light') return saved; 
      const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches; 
      return prefersDark ? 'dark' : 'light'; 
    }
    
    function setTheme(theme, persist = true){
      applyThemeClass(theme);
      const isDark = theme === 'dark';
      
      if (themeToggle) {
        themeToggle.setAttribute('aria-checked', isDark ? 'true' : 'false');
        themeIcon && (themeIcon.innerHTML = isDark ? '<i class="fa-solid fa-moon"></i>' : '<i class="fa-solid fa-sun"></i>');
        themeIcon && themeIcon.classList.add('rotate'); 
        setTimeout(()=> themeIcon && themeIcon.classList.remove('rotate'), 300);
        if (themeDot) themeDot.style.transform = isDark ? 'translateX(22px)' : 'translateX(0)';
      }
      
      if (mobileThemeIcon) mobileThemeIcon.className = isDark ? 'fa-solid fa-moon text-slate-200' : 'fa-solid fa-sun text-yellow-400';
      if (persist) localStorage.setItem(THEME_KEY, theme);
    }
    
    function toggleTheme(){ 
      const cur = document.documentElement.classList.contains('dark') ? 'dark' : 'light'; 
      setTheme(cur === 'dark' ? 'light' : 'dark', true); 
    }
    
    (function initTheme(){ 
      const initial = getInitialTheme(); 
      setTheme(initial, false); 
    })();
    
    if (themeToggle) themeToggle.addEventListener('click', toggleTheme);
    if (themeToggle) themeToggle.addEventListener('keydown', (e) => { 
      if (e.key === ' ' || e.key === 'Spacebar' || e.key === 'Enter') { 
        e.preventDefault(); 
        toggleTheme(); 
      } 
    });
    
    if (mobileThemeToggle) mobileThemeToggle.addEventListener('click', toggleTheme);

    // Mobile menu toggle
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener('click', ()=> {
        mobileMenu.classList.toggle('open');
        mobileMenu.classList.toggle('hidden');
        
        // Change icon based on menu state
        const icon = menuToggle.querySelector('i');
        if (mobileMenu.classList.contains('open')) {
          icon.className = 'fas fa-times text-xl text-gray-700 dark:text-slate-200';
        } else {
          icon.className = 'fas fa-bars text-xl text-gray-700 dark:text-slate-200';
        }
      });
    }

    // set copyright year
    const ye = document.getElementById('currentYear'); 
    if (ye) ye.textContent = new Date().getFullYear();
  </script>

  <!-- ========== SCRIPT: support page logic (copy, accordion) ========== -->
  <script>
    // Copy buttons with improved toast
    function copyToClipboard(text, btn) {
      if (!navigator.clipboard) {
        // fallback
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        document.body.appendChild(ta);
        ta.focus(); 
        ta.select();
        try { 
          document.execCommand('copy'); 
        } catch(e){}
        document.body.removeChild(ta);
        showToast('Teks berhasil disalin');
        return;
      }
      
      navigator.clipboard.writeText(text).then(()=> {
        showToast('Teks berhasil disalin');
      }, ()=> {
        showToast('Gagal menyalin teks');
      });
    }

    function showToast(msg) {
      // Create toast element
      const toast = document.createElement('div');
      toast.className = 'toast';
      toast.innerHTML = `
        <div class="flex items-center gap-3">
          <div class="w-6 h-6 rounded-full bg-green-500 flex items-center justify-center text-white">
            <i class="fa-solid fa-check text-xs"></i>
          </div>
          <span>${msg}</span>
        </div>
      `;
      
      document.body.appendChild(toast);
      
      // Show toast
      setTimeout(() => {
        toast.classList.add('show');
      }, 10);
      
      // Hide and remove toast
      setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => {
          document.body.removeChild(toast);
        }, 300);
      }, 3000);
    }

    // Attach copy event listeners
    document.getElementById('copy-email')?.addEventListener('click', (e)=>{
      copyToClipboard('<%= config.contact.email %>', e.target);
    });
    
    document.getElementById('copy-wa')?.addEventListener('click', (e)=>{
      copyToClipboard('<%= config.contact.whatsapp %>', e.target);
    });
    
    document.getElementById('copy-tg')?.addEventListener('click', (e)=>{
      copyToClipboard('<%= config.contact.telegram %>', e.target);
    });

    // Accordion behavior
    document.querySelectorAll('[data-acc]').forEach(header => {
      header.addEventListener('click', () => {
        const item = header.closest('.accordion-item');
        if (!item) return;
        
        const body = item.querySelector('.acc-body');
        const toggle = item.querySelector('.acc-toggle i');
        
        if (!body) return;
        
        const isOpen = !body.classList.contains('hidden');
        
        // Close all other accordion items
        document.querySelectorAll('.accordion-item').forEach(otherItem => {
          if (otherItem !== item) {
            const otherBody = otherItem.querySelector('.acc-body');
            const otherToggle = otherItem.querySelector('.acc-toggle i');
            
            if (otherBody) otherBody.classList.add('hidden');
            if (otherToggle) otherToggle.classList.remove('fa-rotate-180');
          }
        });
        
        // Toggle current item
        if (isOpen) {
          body.classList.add('hidden');
          toggle.classList.remove('fa-rotate-180');
        } else {
          body.classList.remove('hidden');
          toggle.classList.add('fa-rotate-180');
        }
      });
    });

    // Accessibility: allow keyboard toggle for accordion headers
    document.querySelectorAll('.acc-header').forEach(h => {
      h.setAttribute('tabindex', '0');
      h.addEventListener('keydown', (ev) => {
        if (ev.key === 'Enter' || ev.key === ' ') {
          ev.preventDefault();
          h.click();
        }
      });
    });

    // Initialize page with first accordion open
    document.addEventListener('DOMContentLoaded', () => {
      const firstAccordion = document.querySelector('.accordion-item');
      if (firstAccordion) {
        const firstBody = firstAccordion.querySelector('.acc-body');
        const firstToggle = firstAccordion.querySelector('.acc-toggle i');
        
        if (firstBody && firstToggle) {
          firstBody.classList.remove('hidden');
          firstToggle.classList.add('fa-rotate-180');
        }
      }
    });
  </script>

</body>
